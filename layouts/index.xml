{{- $blogPages := where site.RegularPages "Section" "blog" -}}
{{- $pctx := . -}}
{{- if gt (len $blogPages) 0 -}}
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>{{ .Site.Title }}</title>
    <link>{{ .Permalink }}</link>
    <description>{{ .Site.Params.description | default "Recent content" }}</description>
    <generator>Hugo</generator>
    <language>{{ .Site.LanguageCode }}</language>
    <lastBuildDate>{{ (index $blogPages 0).Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" }}</lastBuildDate>
    <atom:link href="{{ "feed.xml" | absURL }}" rel="self" type="application/rss+xml" />
    {{- range first 20 $blogPages }}
    <item>
      <title>{{ .Title }}</title>
      <link>{{ .Permalink }}</link>
      <pubDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" }}</pubDate>
      <guid>{{ .Permalink }}</guid>
      <description>{{ .Params.intro | default .Summary | html }}</description>
    </item>
    {{- end }}
  </channel>
</rss>
{{- end -}}
